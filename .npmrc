# Copy file: dependencies (the local eslint-plugin-lumo at .eslint-rules/)
# instead of symlinking. Symlinks fail on SMB / network-share workspaces on
# Windows. Keep this file committed so the install works on any host regardless
# of the filesystem underneath.
install-links=true

# Native rebuild lives inside electron-builder's install-app-deps postinstall;
# no loglevel tweak needed beyond what package.json scripts pass.
