{
  "name": "lumo",
  "version": "0.0.0",
  "private": true,
  "description": "Single-operator Windows desktop app that turns a prompt into a lip-synced branded avatar video.",
  "author": {
    "name": "Kenny Lowe",
    "email": "kenny.lowe@gmail.com"
  },
  "license": "UNLICENSED",
  "main": "dist/main/bootstrap.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.preload.json && tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.tests.json",
    "lint": "eslint . --ext .ts,.tsx,.cjs,.js",
    "lint:fix": "eslint . --ext .ts,.tsx,.cjs,.js --fix",
    "format": "prettier --write \"**/*.{ts,tsx,md,yml,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,yml,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "playwright test",
    "package": "npm run build && electron-builder --win --config build/electron-builder.yml",
    "rebuild": "electron-rebuild -f -w better-sqlite3,keytar",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.645.0",
    "@aws-sdk/s3-request-presigner": "^3.645.0",
    "@monaco-editor/react": "^4.6.0",
    "@remotion/bundler": "^4.0.200",
    "@remotion/player": "^4.0.200",
    "@remotion/renderer": "^4.0.200",
    "@vladmandic/face-api": "^1.7.14",
    "better-sqlite3": "^11.3.0",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "keytar": "^7.9.0",
    "monaco-editor": "^0.50.0",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.200",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@playwright/test": "^1.47.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-lumo": "file:./.eslint-rules",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  }
}
