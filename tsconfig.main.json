{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist/main",
    "rootDir": ".",
    "types": ["node", "electron", "react"],
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx"
  },
  "include": [
    "src/main/**/*.ts",
    "src/shared/**/*.ts",
    "src/types/**/*.d.ts",
    "resources/templates/**/*.tsx"
  ]
}
